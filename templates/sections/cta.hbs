<section class="cta">
  <div class="cta-bg"></div>
  <div class="cta-content">
    <div class="cta-glow"></div>
    <h2 class="cta-headline">{{headline}}</h2>
    {{#if description}}
    <p class="cta-description">{{description}}</p>
    {{/if}}
    {{#if buttonText}}
    <a href="{{buttonLink}}" class="cta-button">
      <span>{{buttonText}}</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
      <div class="cta-button-glow"></div>
    </a>
    {{/if}}
  </div>
</section>

<style>
.cta {
  position: relative;
  padding: 140px 24px;
  background: var(--bg);
  overflow: hidden;
}

.cta-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 100% 80% at 50% 120%, var(--primary), transparent 70%);
  opacity: 0.4;
}

.cta-content {
  position: relative;
  z-index: 10;
  text-align: center;
  max-width: 800px;
  margin: 0 auto;
}

.cta-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
  opacity: 0.15;
  filter: blur(60px);
  pointer-events: none;
}

.cta-headline {
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 800;
  color: var(--text);
  margin-bottom: 20px;
  letter-spacing: -0.02em;
  animation: fadeInUp 0.6s ease-out forwards;
  opacity: 0;
}

.cta-description {
  font-size: clamp(1rem, 2vw, 1.25rem);
  color: var(--text-muted);
  margin-bottom: 40px;
  max-width: 500px;
  margin-left: auto;
  margin-right: auto;
  animation: fadeInUp 0.6s ease-out 0.1s forwards;
  opacity: 0;
}

.cta-button {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 18px 44px;
  background: var(--primary);
  color: var(--bg);
  text-decoration: none;
  border-radius: 50px;
  font-size: 1.15rem;
  font-weight: 700;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeInUp 0.6s ease-out 0.2s forwards;
  opacity: 0;
  overflow: hidden;
}

.cta-button::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.3), transparent 50%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.cta-button:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 25px 50px -15px var(--primary);
}

.cta-button:hover::before {
  opacity: 1;
}

.cta-button svg {
  transition: transform 0.3s ease;
}

.cta-button:hover svg {
  transform: translateX(4px);
}

.cta-button-glow {
  position: absolute;
  inset: -2px;
  background: var(--primary);
  border-radius: 50px;
  filter: blur(20px);
  opacity: 0.4;
  z-index: -1;
  transition: opacity 0.4s ease;
}

.cta-button:hover .cta-button-glow {
  opacity: 0.7;
}

@media (max-width: 768px) {
  .cta {
    padding: 100px 20px;
  }
  
  .cta-content {
    padding: 0 16px;
  }
  
  .cta-button {
    padding: 16px 36px;
    font-size: 1rem;
  }
}
</style>